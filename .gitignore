# ---- 环境变量 / 密钥 ----
.env
.env.*
!.env.example
*.local
*.pem
*.key
*.p12
*.pfx
*credentials*
*secret*

# ---- 依赖 ----
node_modules/
vendor/

# ---- 构建产物 ----
dist/
dist-ssr/
build/
*.out
backend/server
