backend/data/runtime/*
!backend/data/runtime/.gitkeep

# ---- 日志 ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- 编辑器 / 系统 ----
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.swp
*.swo
